# MedCloud environment configuration (EXAMPLE — placeholders only, never commit a real .env)
# Copy this file to ".env" and fill in real values. Any variable left blank makes the
# related service run in its documented fallback mode, so the app still works for a demo.

# ----- Flask core -----
# Secret key for sessions and CSRF. Generate one with: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret
FLASK_ENV=development
# Debug defaults to OFF (see app/config.py) so a fresh clone is production-safe.
# Set to 1 only for local development (enables the auto-reloader and interactive debugger).
FLASK_DEBUG=1

# ----- Database: MongoDB Atlas (cloud NoSQL) -----
# If MONGO_URI is empty, the app automatically falls back to an in-memory database (mongomock),
# so you can run and demo the whole system with zero cloud credentials.
MONGO_URI=
MONGO_DB_NAME=medcloud

# ----- Demo user seeding -----
# Demo accounts (admin@/doctor@/pharmacist@example.com) are seeded automatically whenever
# MONGO_URI is empty (in-memory demo database). If MONGO_URI IS set (a real database),
# seeding is skipped unless you explicitly set SEED_DEMO_USERS=true — this prevents a real
# deployment from silently getting known demo1234-password accounts.
SEED_DEMO_USERS=
# Password used for the seeded demo accounts. Not a real secret — change it if you seed
# demo users into a database anyone else can reach.
DEMO_PASSWORD=demo1234

# ----- Cloud storage: Cloudinary (prescription PDFs) -----
# If these are empty, generated PDFs are stored locally under generated_pdfs/ instead.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- Diagnosis / medical search: Tavily -----
# If empty, search_service falls back to OpenFDA (for drug-related queries), then to a clear message.
TAVILY_API_KEY=

# ----- OCR for handwritten prescriptions -----
# Primary provider: Hugging Face Inference API running a TrOCR handwritten-text model.
# Get a free token at https://huggingface.co/settings/tokens.
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_OCR_MODEL=microsoft/trocr-base-handwritten
# Optional generic cloud OCR endpoint (escape hatch for a different provider).
OCR_API_URL=
OCR_API_KEY=
# If none of the above are configured, ocr_service falls back to local Tesseract,
# then to manual transcription by the pharmacist.

# ----- AI document validator (bonus) -----
# Hosted vision model endpoint used to check an upload looks like a real prescription/document.
# If empty, the validator falls back to local heuristics (type/size/dimensions/aspect ratio).
VISION_API_URL=
VISION_API_KEY=

# ----- ClinicalTrials.gov -----
# Public API, no key required. Override only if you need a custom base URL.
CLINICAL_TRIALS_BASE_URL=https://clinicaltrials.gov/api/v2

# ----- OpenFDA (drug label fallback for search) -----
# Public API, no key required. Override only if you need a custom base URL.
OPENFDA_BASE_URL=https://api.fda.gov

# ----- Bonus future extensions (documented stubs only, disabled by default) -----
KAFKA_ENABLED=0
KAFKA_BOOTSTRAP_SERVERS=
OLLAMA_ENABLED=0
OLLAMA_BASE_URL=http://localhost:11434
